unit Controller.Livro;

interface

uses

  ListaLivros, Model.Livro, Service.Livro, System.Classes, System.SysUtils, System.Threading, Vcl.Dialogs;

type

  TLivroController = class

    private

    FOwner: TfrmListaLivros;
    FService: ILivroService;

    public

    constructor Create(Owner: TfrmListaLivros; Service: ILivroService);
    procedure ObterLivros(pSender: TObject);
    procedure Salvar (Livro: TLivroModel);
    procedure Excluir (id: integer);

  end;

implementation

{ TLivroController }

constructor TLivroController.Create(Owner: TfrmListaLivros;
  Service: ILivroService);
begin
  FOwner:= Owner;
  FService:= Service;
end;

procedure TLivroController.ObterLivros(pSender: TObject);
begin
    TTask.Run(
    procedure
    begin
      try
        var Livro := FService.ObterLivros;
        TThread.Synchronize(nil,
        procedure
        begin
          FOwner.lstLivros.Clear;
          for var Livro in Livro do
          begin
            FOwner.pSender.AddItem(Livro.Titulo ,Livro);
          end;
        end
        );
      except
        on E: exception do
          TThread.Synchronize(nil,
          procedure
          begin
            ShowMessage('Erro: ' + E.Message);
          end
          );
      end;
    end
  )
end;

procedure TLivroController.Salvar(Livro: TLivroModel);
begin
  FService.Salvar(Livro);
end;

procedure TLivroController.Excluir(id: integer);
begin
  FService.Excluir(id);
end;

end.
