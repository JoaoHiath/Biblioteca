unit Controller.Emprestimo;

interface


uses

  Vcl.Controls, ListaEmprestimos, Model.Livro, Model.Emprestimo, Service.Emprestimo, Service.Cliente,System.Classes, System.SysUtils, System.Threading, Vcl.Dialogs;

type

  TEmprestimoController = class

    private

    FOwner: TComponent;
    FServiceEmprestimo: IEmprestimoService;
    FServiceCliente: IClienteService;

    public

    constructor Create(pOwner: TComponent; pServiceEmprestimo: IEmprestimoService; pServiceCliente: IClienteService);
    procedure ObterEmprestimos(pLista: TCustomListControl);
    procedure ObterEmprestimosFiltroLivro(pLista: TCustomListControl; pIdLivro: string; pStatus: string);
    procedure RealizarEmprestimo (pEmprestimo: TEmprestimoModel; pLivro: TLivroModel);
    procedure Excluir (pId: integer);

  end;

implementation

{ TClienteController }

constructor TEmprestimoController.Create(pOwner: TComponent;
  pServiceEmprestimo: IEmprestimoService; pServiceCliente: IClienteService);
begin
  FOwner:= pOwner;
  FServiceEmprestimo:= pServiceEmprestimo;
  FServiceCliente := pServiceCliente;
end;

procedure TEmprestimoController.ObterEmprestimos(pLista: TCustomListControl);
begin
  try
    var Emprestimos := FServiceEmprestimo.ObterEmprestimo;
    pLista.Clear;

    for var Emprestimo in Emprestimos do
    begin
      var Cliente := FServiceCliente.ObterClienteId(Emprestimo.IdCliente);
      pLista.AddItem(' Cliente: ' + Cliente.Nome + ' Entrega: ' + DateToStr(Emprestimo.DataEmprestimo),Emprestimo);
    end;

  except
    on E: exception do
      ShowMessage('Erro: ' + E.Message);
  end;
end;

procedure TEmprestimoController.ObterEmprestimosFiltroLivro(pLista: TCustomListControl; pIdLivro: string; pStatus: string);
begin
    try
    var Emprestimos := FServiceEmprestimo.ObterEmprestimosFiltroLivro(pIdLivro,pStatus);
    pLista.Clear;

    for var Emprestimo in Emprestimos do
    begin
      var Cliente := FServiceCliente.ObterClienteId(Emprestimo.IdCliente);
      pLista.AddItem(' Cliente: ' + Cliente.Nome + ' Entrega: ' + DateToStr(Emprestimo.DataEmprestimo),Emprestimo);
    end;

  except
    on E: exception do
      ShowMessage('Erro: ' + E.Message);
  end;
end;

procedure TEmprestimoController.RealizarEmprestimo(pEmprestimo: TEmprestimoModel; pLivro: TLivroModel);
begin
  FServiceEmprestimo.RealizarEmprestimo(pEmprestimo, pLivro);
end;

procedure TEmprestimoController.Excluir(pId: integer);
begin
  FServiceEmprestimo.Excluir(pId);
end;

end.
