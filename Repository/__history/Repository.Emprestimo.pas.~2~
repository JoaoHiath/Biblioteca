unit Repository.Emprestimo;

interface

uses

  Data.DB, DataModulePrincipal, Generics.Collections,Model.Emprestimo, System.Classes;

type

 IEmprestimoRepository = interface

   function ObterEmprestimos: TObjectList <TEmprestimoModel>;
   procedure Salvar (Emprestimo: TEmprestimoModel);
   procedure Excluir (id: integer);
 end;

 TEmprestimoRepository = class (TInterfacedObject, IEmprestimoRepository)
   public
     function ObterEmprestimos: TObjectList <TEmprestimoModel>;
     procedure Salvar (Emprestimo: TEmprestimoModel);
     procedure Excluir (id: integer);

 end;

implementation

{ TEmprestimoRepository }

function TEmprestimoRepository.ObterEmprestimos: TObjectList<TEmprestimoModel>;
begin

    Result := TObjectList<TEmprestimoModel>.Create;

    dtmPrincipal.FDTEmprestimo.First;

    while not dtmPrincipal.FDTEmprestimo.Eof do
    begin
      var Emprestimo := TEmprestimoModel.Create;

      Emprestimo.id := dtmPrincipal.FDTEmprestimoid.AsInteger;
      Emprestimo.IdLivro := dtmPrincipal.FDTEmprestimoid_livro.AsInteger;
      Emprestimo.IdCliente := dtmPrincipal.FDTEmprestimoid_cliente.AsInteger;
      Emprestimo.DataDevolucao := dtmPrincipal.FDTEmprestimodata_devolucao.AsDateTime;
      Emprestimo.DataEmprestimo := dtmPrincipal.FDTEmprestimodata_emprestimo.AsDateTime;
      Emprestimo.DataPrevistaDevolucao := dtmPrincipal.FDTEmprestimodata_prevista_devolucao.AsDateTime;
      Emprestimo.Status := dtmPrincipal.FDTEmprestimostatus.AsString;

      Result.Add(Emprestimo);

      dtmPrincipal.FDTCliente.Next;
    end;

end;

procedure TEmprestimoRepository.Salvar(Emprestimo: TEmprestimoModel);
begin
    if dtmPrincipal.FDTEmprestimo.Locate('id', Emprestimo.id, []) then
      dtmPrincipal.FDTEmprestimo.Edit
    else
    dtmPrincipal.FDTEmprestimo.Append;

    dtmPrincipal.FDTEmprestimoid_livro.AsInteger := Emprestimo.IdLivro;
    dtmPrincipal.FDTEmprestimoid_cliente.AsInteger := Emprestimo.IdCliente;
    dtmPrincipal.FDTEmprestimodata_devolucao.AsDateTime := Emprestimo.DataDevolucao;
    dtmPrincipal.FDTEmprestimodata_emprestimo.AsDateTime := Emprestimo.DataEmprestimo;
    dtmPrincipal.FDTEmprestimodata_prevista_devolucao.AsDateTime := Emprestimo.DataPrevistaDevolucao;
    dtmPrincipal.FDTEmprestimostatus.AsString := Emprestimo.Status;

    Emprestimo.id := dtmPrincipal.FDTEmprestimoid.AsInteger;

end;

procedure TEmprestimoRepository.Excluir(id: integer);
begin

  if dtmPrincipal.FDTEmprestimo.Locate('id', id, []) then
    dtmPrincipal.FDTEmprestimo.Delete;

end;

end.
