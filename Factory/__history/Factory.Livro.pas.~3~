unit Factory.Livro;

interface

uses

  Controller.Livro, Service.Livro, Repository.Livro, ListaLivros;

type

  TClienteFactory = class
    public
    class function criarController(owner: TfrmListaLivros): TLivroController;
    class function criarService: ILivroService;
    class function criarRepository: ILivroRepository;
  end;

implementation

{ TClienteFactory }

class function TClienteFactory.criarController(
  owner: TfrmListaLivros): TLivroController;
begin
  var Service:= CriarService;

  Result := TLivroController.Create(owner, service);
end;

class function TClienteFactory.criarRepository: ILivroRepository;
begin
  Result := TLivroRepository.Create;
end;

class function TClienteFactory.criarService: ILivroService;
begin
  var Repository:= CriarRepository;

  Result:= TLivroService.Create(Repository);
end;

end.
